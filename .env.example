DATABASE_URL="postgresql://cpa:cpa@localhost:5432/cpa_jobs?schema=public"
JWT_SECRET="replace-with-a-long-random-secret"
PORT=4000
WEB_ORIGIN="http://localhost:3000"
NEXT_PUBLIC_API_BASE_URL="http://localhost:4000"
ENABLE_SWAGGER=true

# Optional AI features
OPENAI_API_KEY=""

# Company logo uploads. In AWS, prefer IAM role credentials for the API server.
AWS_REGION="ap-northeast-2"
S3_ASSET_BUCKET="your-public-logo-bucket"
S3_PUBLIC_BASE_URL="https://your-public-logo-bucket.s3.ap-northeast-2.amazonaws.com"
S3_PRESIGN_EXPIRES_SECONDS=300
NEXT_PUBLIC_S3_PUBLIC_BASE_URL="https://your-public-logo-bucket.s3.ap-northeast-2.amazonaws.com"

# Production EC2 + Caddy + S3 static web hosting values live in
# deploy/production.env.example. For static web builds, set:
# NEXT_PUBLIC_API_BASE_URL="/api"
